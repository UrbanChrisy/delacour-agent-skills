{
	"cli": {
		"version": ">=16.10",
		"appVersionSource": "remote"
	},
	"build": {
		"base": {
			"channel": "base",
			"resourceClass": "medium",
			"bun": "1.3.5"
		},
		"ios-simulator": {
			"extends": "base",
			"ios": {
				"simulator": true
			}
		},
		"development": {
			"extends": "base",
			"developmentClient": true,
			"distribution": "internal",
			"channel": "development"
		},
		"cicd": {
			"extends": "base",
			"developmentClient": true,
			"distribution": "internal",
			"ios": {
				"simulator": true
			},
			"channel": "cicd"
		},
		"production": {
			"extends": "base",
			"environment": "production",
			"distribution": "store",
			"channel": "production",
			"autoIncrement": true
		}
	},
	"submit": {
		"base": {
			"android": {
				"track": "internal",
				"changesNotSentForReview": true,
				"releaseStatus": "draft"
			},
			"ios": {
				"ascAppId": "<ios_app_store_id>",
				"appleTeamId": "<ios_apple_team_id>"
			}
		},
		"production": {
			"extends": "base"
		}
	}
}
